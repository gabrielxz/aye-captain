# Anthropic API key for the LLM translator (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Groq API key for voice input (Whisper speech-to-text). Optional: without it
# push-to-talk falls back to the browser's Web Speech API.
GROQ_API_KEY=gsk_...

# ElevenLabs API key for the ship AI's voice. Optional: without it the ship
# speaks in text only.
ELEVENLABS_API_KEY=...

# Optional overrides
# STT_API_KEY=...                      # explicit STT key (else GROQ/OPENAI key is used)
# STT_BASE_URL=https://api.openai.com/v1   # any OpenAI-compatible /audio/transcriptions host
# STT_MODEL=gpt-4o-mini-transcribe
# UTTERANCE_LOG=data/utterances.jsonl  # where captain utterances are recorded
# SPEECH_CACHE_DIR=data/speech         # where generated voice lines are cached

# Port to bind (defaults to 8080)
PORT=8080
